################################################################################
# .gitignore for LaunchPad - ASP.NET Core
################################################################################

# Build outputs
[Bb]in/
[Oo]bj/
[Dd]ebug/
[Rr]elease/

# Visual Studio
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates
LaunchPad.sln.DotSettings.user

# NuGet
*.nupkg
**/packages/

# Bower / npm — exclude everything inside lib/ except the vendored CodeMirror
# bundle, which is committed so the app works offline without a CDN.
LaunchPad/wwwroot/lib/*
!LaunchPad/wwwroot/lib/codemirror/
node_modules/

# SQLite databases (created at runtime)
LaunchPad/*.db
LaunchPad/*.db-journal
LaunchPad/*.db-wal
LaunchPad/*.db-shm

# Local PowerShell script folder (created at runtime; do not commit)
LaunchPad/Scripts/

# User-specific configuration
appsettings.*.local.json

# OS files
.DS_Store
Thumbs.db
