@model LaunchPad.ViewModels.PowerShellViewModel
@{
    ViewBag.Title = $"Edit · {Model.Name}";
}

<style>
    .author { display: grid; grid-template-columns: 1fr; gap: var(--s-xl); }

    .author__head {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: var(--s-md);
        padding-bottom: var(--s-md);
        border-bottom: 1px solid var(--rule);
    }
    .author__title { display: flex; align-items: baseline; gap: var(--s-md); flex-wrap: wrap; }
    .author__title h1 { font-size: var(--t-h2); letter-spacing: -0.022em; }
    .author__title .meta {
        font-family: var(--mono);
        font-variation-settings: var(--rec-mono-tight);
        font-size: var(--t-meta);
        color: var(--fg-3);
        letter-spacing: 0;
    }
    .author__title .dirty-dot {
        width: 8px; height: 8px;
        border-radius: 50%;
        background: var(--accent);
        box-shadow: 0 0 0 4px color-mix(in oklab, var(--accent) 28%, transparent);
        animation: pulse 1.4s ease-in-out infinite;
        align-self: center;
    }
    .author__title .dirty-dot[hidden] { display: none; }

    .author__form { display: grid; grid-template-columns: 1fr; gap: var(--s-lg); max-width: 1100px; }
    .author__row {
        display: grid;
        grid-template-columns: 180px 1fr;
        gap: var(--s-md);
        align-items: baseline;
    }
    .author__row label {
        font-size: var(--t-meta);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--fg-2);
        margin: 0;
    }
    .author__row .name-locked {
        font-family: var(--mono);
        font-variation-settings: var(--rec-mono-tight);
        font-size: var(--t-ui);
        color: var(--fg-1);
        padding: 0.5em 0.7em;
        background: var(--bg-1);
        border: 1px solid var(--rule);
        border-radius: 4px;
        display: inline-flex;
        align-items: center;
        gap: 0.5em;
        max-width: 36ch;
    }
    .author__row .name-locked .lock-tag {
        font-size: var(--t-micro);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--fg-3);
        padding: 0.05em 0.35em;
        background: var(--bg-2);
        border: 1px solid var(--rule);
        border-radius: 3px;
    }

    .editor-block { display: flex; flex-direction: column; gap: var(--s-xs); }
    .editor-block__head {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: var(--s-sm);
        padding: 0.5em 0 var(--s-xs);
    }
    .editor-block__head h3 {
        font-size: var(--t-meta);
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--fg-2);
        font-weight: 600;
    }
    .editor-block__head .meta {
        font-family: var(--mono);
        font-variation-settings: var(--rec-mono-tight);
        font-size: var(--t-meta);
        color: var(--fg-3);
    }

    /* Textarea is the canonical form value but visually replaced by CodeMirror. */
    .author__form textarea[name="Script"] {
        position: absolute;
        left: -9999px;
        width: 1px;
        height: 1px;
        opacity: 0;
        pointer-events: none;
    }

    .author__actions {
        display: flex;
        gap: var(--s-md);
        align-items: center;
        padding-top: var(--s-md);
        border-top: 1px solid var(--rule);
    }
    .author__actions .kbd-hint {
        margin-left: auto;
        font-family: var(--mono);
        font-variation-settings: var(--rec-mono-tight);
        font-size: var(--t-meta);
        color: var(--fg-3);
    }
    .author__actions .kbd-hint kbd {
        display: inline-block;
        padding: 0.05em 0.35em;
        font-size: 0.85em;
        color: var(--fg-1);
        background: var(--bg-2);
        border: 1px solid var(--rule-strong);
        border-radius: 3px;
        font-family: var(--mono);
        font-variation-settings: var(--rec-mono-tight);
    }

    .ghost {
        font-family: var(--mono);
        font-variation-settings: var(--rec-mono-tight);
        font-size: var(--t-meta);
        color: var(--fg-2);
        padding: 0.4em 0.8em;
        border: 1px solid var(--rule);
        background: transparent;
        border-radius: 4px;
        text-decoration: none;
        cursor: pointer;
    }
    .ghost:hover { color: var(--fg-0); border-color: var(--rule-strong); background: var(--bg-1); }

    .validation-summary-errors,
    .field-validation-error,
    .text-danger {
        color: var(--fail);
        font-family: var(--mono);
        font-variation-settings: var(--rec-mono);
        font-size: var(--t-meta);
    }
    .validation-summary-errors {
        padding: var(--s-sm) var(--s-md);
        background: color-mix(in oklab, var(--fail) 8%, var(--bg-1));
        border: 1px solid color-mix(in oklab, var(--fail) 45%, var(--rule-strong));
        border-radius: 4px;
        margin-bottom: var(--s-md);
    }

    .draft-pill {
        display: flex;
        align-items: center;
        gap: var(--s-sm);
        padding: var(--s-xs) var(--s-sm);
        margin-bottom: var(--s-xs);
        font-family: var(--mono);
        font-variation-settings: var(--rec-mono-tight);
        font-size: var(--t-meta);
        color: var(--fg-2);
        background: color-mix(in oklab, var(--accent) 8%, var(--bg-1));
        border: 1px solid color-mix(in oklab, var(--accent) 35%, var(--rule-strong));
        border-radius: 4px;
    }
    .draft-pill[hidden] { display: none; }
    .draft-pill__label { color: var(--fg-1); }
    .draft-pill__action {
        font-family: var(--mono);
        font-variation-settings: var(--rec-mono-tight);
        font-size: var(--t-meta);
        color: var(--fg-1);
        background: var(--bg-2);
        border: 1px solid var(--rule);
        padding: 0.15em 0.5em;
        border-radius: 3px;
        cursor: pointer;
    }
    .draft-pill__action:hover { color: var(--fg-0); border-color: var(--rule-strong); }
    .draft-pill__action--ghost { background: transparent; color: var(--fg-3); }

    .params-preview {
        display: flex;
        align-items: baseline;
        flex-wrap: wrap;
        gap: var(--s-sm);
        padding: var(--s-xs) var(--s-sm);
        margin-top: var(--s-xs);
        font-family: var(--mono);
        font-variation-settings: var(--rec-mono-tight);
        font-size: var(--t-meta);
        color: var(--fg-2);
        background: var(--bg-1);
        border: 1px solid var(--rule);
        border-left: 1px solid var(--accent-soft);
        border-radius: 4px;
        letter-spacing: 0;
    }
    .params-preview[hidden] { display: none; }
    .params-preview__label {
        font-size: var(--t-micro);
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--fg-3);
        flex: 0 0 auto;
    }
    .params-preview__msg { color: var(--fg-2); }
    .params-preview.is-empty { border-left-color: var(--rule); }
    .params-preview.is-error { border-left-color: var(--fail); }
    .params-preview.is-error .params-preview__msg { color: var(--fail); }
    .params-preview .arg { display: inline-flex; align-items: baseline; }
    .params-preview .arg__k { color: var(--fg-1); }
    .params-preview .arg__sep { color: var(--fg-3); padding: 0 0.15em; }
    .params-preview .arg__v { color: var(--accent); }

    @@media (max-width: 720px) {
        .author__row { grid-template-columns: 1fr; }
        .author__row label { padding-bottom: var(--s-2xs); }
    }
</style>

<section class="author">
    <header class="author__head">
        <div class="author__title">
            <h1>@Model.Name</h1>
            <span class="meta">@(Model.Name + ".ps1") · edit</span>
            <span class="dirty-dot" data-dirty-dot hidden title="unsaved changes"></span>
        </div>
        <a class="ghost" asp-action="Details" asp-route-id="@Model.Id">cancel</a>
    </header>

    <form asp-action="Edit" method="post" class="author__form" data-author-form data-draft-key="lp.draft.edit.@Model.Id">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="Name" />

        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

        <div class="author__row">
            <label>name</label>
            <div>
                <span class="name-locked">@Model.Name<span class="lock-tag">read-only</span></span>
            </div>
        </div>

        <div class="author__row">
            <label for="Category_Id">category</label>
            <select id="Category_Id" name="Category.Id" asp-items="ViewBag.Categories" required data-lp-select></select>
        </div>

        <div class="editor-block">
            <header class="editor-block__head">
                <h3>script</h3>
                <span class="meta">powershell · @(Model.Name + ".ps1")</span>
            </header>
            <div class="draft-pill" data-draft-restore hidden></div>
            <div class="editor-mount" data-script-editor data-target="Script"></div>
            <textarea id="Script" name="Script">@Model.Script</textarea>
            <div class="params-preview is-empty" data-params-preview hidden></div>
            <span asp-validation-for="Script" class="field-validation-error"></span>
        </div>

        <div class="author__actions">
            <button type="submit" class="btn btn-primary">save changes</button>
            <a class="ghost" asp-action="Details" asp-route-id="@Model.Id">cancel</a>
            <span class="kbd-hint"><kbd data-kbd-save>⌘S</kbd> to save</span>
        </div>
    </form>
</section>

@section Scripts {
    <script type="module" src="~/lib/codemirror/ps-editor.bundle.js" asp-append-version="true"></script>
}
