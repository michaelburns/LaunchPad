@using LaunchPad.Models
@using Microsoft.AspNetCore.Authorization
@inject IAuthorizationService AuthorizationService
@{
    ViewData["Title"] = "Home";
    var scripts      = (System.Collections.Generic.List<Script>)ViewBag.Scripts;
    var recentJobs   = (System.Collections.Generic.List<Job>)ViewBag.RecentJobs;
    Job runningJob   = ViewBag.RunningJob;
    int failed24h    = ViewBag.FailedCount24h ?? 0;
    int completed24h = ViewBag.CompletedCount24h ?? 0;
    var canAuthor    = (await AuthorizationService.AuthorizeAsync(User, "Author")).Succeeded;

    string statusToken(Status s) => s switch {
        Status.Completed => "completed",
        Status.Running   => "running",
        Status.Started   => "running",
        Status.Failed    => "failed",
        Status.Scheduled => "scheduled",
        Status.Recurring => "scheduled",
        Status.Cancelled => "warning",
        _                => "pending"
    };

    string statusLabel(Status s) => s.ToString().ToLowerInvariant();

    // 3-letter mono token for the dense rail. Recognition over recall — never color-only.
    string statusShort(Status s) => s switch {
        Status.Completed => "ok",
        Status.Running   => "run",
        Status.Started   => "run",
        Status.Failed    => "fail",
        Status.Scheduled => "sch",
        Status.Recurring => "rec",
        Status.Cancelled => "cnl",
        _                => "—"
    };

    string ago(DateTime d) {
        var t = DateTime.Now - d;
        if (t.TotalSeconds < 60)  return $"{(int)t.TotalSeconds}s ago";
        if (t.TotalMinutes < 60)  return $"{(int)t.TotalMinutes}m ago";
        if (t.TotalHours   < 24)  return $"{(int)t.TotalHours}h ago";
        return $"{(int)t.TotalDays}d ago";
    }

    // First line of the outcome, capped, used as a tooltip on failed-row status pills
    // so an operator can peek at the failure reason without clicking through.
    // Outcome is segment JSON for structured runs — pull the first text segment if
    // we can, otherwise treat the input as plain text.
    string firstLine(string s) {
        if (string.IsNullOrEmpty(s)) return "";
        var candidate = s;
        if (s.Length > 0 && (s[0] == '[' || s[0] == '{')) {
            try {
                var doc = System.Text.Json.JsonDocument.Parse(s);
                if (doc.RootElement.ValueKind == System.Text.Json.JsonValueKind.Array) {
                    foreach (var seg in doc.RootElement.EnumerateArray()) {
                        if (seg.TryGetProperty("t", out var t) && t.GetString() == "text"
                            && seg.TryGetProperty("v", out var v)) {
                            candidate = v.GetString() ?? s;
                            break;
                        }
                    }
                }
            } catch { /* not JSON; treat as plain text */ }
        }
        var i = candidate.IndexOf('\n');
        var line = i >= 0 ? candidate.Substring(0, i) : candidate;
        line = line.Trim();
        return line.Length > 200 ? line.Substring(0, 200) + "…" : line;
    }
}

<style>
    .home {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 280px;
        gap: var(--s-xl);
        align-items: start;
    }

    /* Script roster — the page's main content. Class name is internal; the user-facing
       term is "scripts" everywhere in the chrome. */
    .roster {
        width: 100%;
        font-size: var(--t-body);
    }
    .roster th {
        text-align: left;
        font-family: var(--mono);
        font-variation-settings: var(--rec-mono-tight);
        font-size: var(--t-meta);
        text-transform: lowercase;
        letter-spacing: 0;
        color: var(--fg-3);
        font-weight: 500;
        padding: var(--s-sm) var(--s-md) var(--s-sm) 0;
        border-bottom: 1px solid var(--rule-strong);
        white-space: nowrap;
    }
    /* Sortable column headers: chevron indicator on the active column, hover lifts colour. */
    .roster th[data-sort-key] {
        cursor: pointer;
        user-select: none;
        position: relative;
        padding-right: 1.4em;
        transition: color 100ms linear;
    }
    .roster th[data-sort-key]:hover { color: var(--fg-1); }
    .roster th[data-sort-key]:focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 2px;
        color: var(--fg-1);
    }
    .roster th[data-sort-key]::after {
        content: "↕";
        position: absolute;
        right: 0.5em;
        top: 50%;
        transform: translateY(-50%);
        color: var(--fg-3);
        opacity: 0;
        font-size: 0.85em;
        transition: opacity 100ms linear, color 100ms linear;
    }
    .roster th[data-sort-key]:hover::after { opacity: 0.5; }
    .roster th.is-sorted { color: var(--fg-1); }
    .roster th.is-sorted::after {
        content: "▴";
        opacity: 1;
        color: var(--accent);
    }
    .roster th.is-sorted.is-sorted-desc::after { content: "▾"; }
    .roster td {
        padding: 0.95em var(--s-md) 0.95em 0;
        border-bottom: 1px solid var(--rule);
        vertical-align: middle;
        color: var(--fg-1);
    }
    .roster tbody tr:hover td,
    .roster tbody tr.is-selected td { background: var(--bg-1); }
    .roster tbody tr:last-child td { border-bottom-color: transparent; }
    .roster .col-name a {
        font-family: var(--sans);
        font-weight: 600;
        font-size: var(--t-body);
        color: var(--fg-0);
        border-bottom: none;
        letter-spacing: -0.012em;
    }
    .roster .col-name a:hover { color: var(--accent); }
    .roster .col-name .cat {
        display: block;
        font-family: var(--mono);
        font-variation-settings: var(--rec-mono-tight);
        font-size: var(--t-meta);
        color: var(--fg-3);
        letter-spacing: 0;
        margin-top: 0.35em;
    }
    .roster .col-author { font-family: var(--mono); font-variation-settings: var(--rec-mono-tight); font-size: var(--t-ui); color: var(--fg-2); }
    .roster .col-last   { font-family: var(--mono); font-variation-settings: var(--rec-mono-tight); font-size: var(--t-ui); color: var(--fg-2); white-space: nowrap; }
    .roster .col-action { text-align: right; white-space: nowrap; }
    .roster .col-action .open {
        display: inline-flex;
        align-items: center;
        gap: 0.4em;
        font-family: var(--mono);
        font-variation-settings: var(--rec-mono-tight);
        font-size: var(--t-ui);
        color: var(--fg-3);
        text-decoration: none;
        border: 1px solid transparent;
        background: transparent;
        padding: 0.4em 0.8em;
        border-radius: 4px;
        opacity: 0.55;
        transition: opacity 100ms linear, background 100ms linear, border-color 100ms linear, color 100ms linear;
    }
    .roster tr:hover .col-action .open,
    .roster tr.is-selected .col-action .open,
    .roster .col-action .open:focus-visible { opacity: 1; color: var(--fg-1); border-color: var(--rule-strong); }
    .roster .col-action .open:hover { background: var(--accent); color: oklch(15% 0.020 50); border-color: var(--accent); }
    /* Last failed row gets a persistent ghost button — likely the row the operator came to fix. */
    .roster tr.is-last-failed .col-action .open { opacity: 1; color: var(--fg-1); border-color: var(--rule-strong); }
    /* Currently running script — mirror the topbar dock signal inline on the row.
       The active-moment exception in the brief: a left edge in accent-soft is allowed
       precisely because the running row is the *one* place the page shouldn't be quiet. */
    .roster tr.is-running td { background: color-mix(in oklab, var(--accent) 11%, transparent); }
    .roster tr.is-running td:first-child {
        box-shadow: inset 2px 0 0 var(--accent);
    }
    .roster tr.is-running .col-name a { color: var(--fg-0); }
    .roster tr.is-running .col-author,
    .roster tr.is-running .col-last { color: var(--fg-1); }

    .roster__head {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        margin-bottom: var(--s-md);
        gap: var(--s-md);
        flex-wrap: wrap;
    }
    .roster__head h2 { font-size: var(--t-h2); letter-spacing: -0.022em; }
    .roster__title { display: flex; align-items: baseline; gap: var(--s-sm); }
    .roster__head .summary {
        font-family: var(--mono);
        font-variation-settings: var(--rec-mono-tight);
        font-size: var(--t-ui);
        color: var(--fg-3);
        letter-spacing: 0;
    }
    .roster__head .summary a { color: inherit; border-bottom: 1px dotted var(--rule-strong); }
    .roster__head .summary a:hover { color: var(--accent); border-bottom-color: var(--accent); }
    .roster__head .summary .fail { color: var(--fail); }
    .roster__head .add {
        font-family: var(--mono);
        font-variation-settings: var(--rec-mono-tight);
        font-size: var(--t-meta);
        color: var(--fg-2);
        border: 1px solid var(--rule);
        background: var(--bg-1);
        padding: 0.3em 0.7em;
        border-radius: 4px;
        text-decoration: none;
    }
    .roster__head .add:hover { color: var(--fg-0); border-color: var(--accent); background: color-mix(in oklab, var(--accent) 8%, var(--bg-1)); }

    /* Filter bar */
    .roster__filter {
        display: grid;
        grid-template-columns: 1fr auto;
        align-items: center;
        gap: var(--s-sm);
        margin-bottom: var(--s-sm);
        padding-bottom: var(--s-xs);
    }
    .roster__filter input[type="search"] {
        background: var(--bg-1);
        border: 1px solid var(--rule);
        font-family: var(--mono);
        font-variation-settings: var(--rec-mono-tight);
        font-size: var(--t-ui);
        padding: 0.45em 0.7em 0.45em 1.8em;
        background-image:
            linear-gradient(transparent, transparent),
            radial-gradient(circle, transparent 0);
        background-position: 0.6em center;
        background-size: auto;
        background-repeat: no-repeat;
    }
    .roster__filter .filter-wrap { position: relative; }
    .roster__filter .filter-wrap::before {
        content: "/";
        position: absolute;
        left: 0.7em;
        top: 50%;
        transform: translateY(-50%);
        font-family: var(--mono);
        font-variation-settings: var(--rec-mono-tight);
        font-size: var(--t-ui);
        color: var(--fg-3);
        pointer-events: none;
    }
    .roster__filter .filter-wrap input { padding-left: 1.7em; padding-right: 2.6em; }
    .roster__filter .filter-clear {
        position: absolute;
        right: 0.5em;
        top: 50%;
        transform: translateY(-50%);
        background: none;
        border: none;
        font-family: var(--mono);
        font-variation-settings: var(--rec-mono-tight);
        font-size: var(--t-meta);
        color: var(--fg-3);
        cursor: pointer;
        padding: 0.15em 0.35em;
        border-radius: 3px;
    }
    .roster__filter .filter-clear:hover { color: var(--fg-0); background: var(--bg-2); }
    .roster__filter .filter-meta {
        font-family: var(--mono);
        font-variation-settings: var(--rec-mono-tight);
        font-size: var(--t-meta);
        color: var(--fg-3);
        white-space: nowrap;
    }

    /* Empty state */
    .roster__empty {
        padding: var(--s-2xl) var(--s-md);
        text-align: left;
        color: var(--fg-2);
        border: 1px dashed var(--rule-strong);
        border-radius: 4px;
        font-family: var(--mono);
        font-variation-settings: var(--rec-mono);
    }
    .roster__empty p { margin-bottom: var(--s-md); }
    .roster__no-match {
        display: none;
        padding: var(--s-lg) var(--s-md);
        font-family: var(--mono);
        font-variation-settings: var(--rec-mono);
        font-size: var(--t-ui);
        color: var(--fg-3);
        border: 1px dashed var(--rule);
        border-radius: 4px;
        margin-top: var(--s-sm);
    }
    .roster.is-empty + .roster__no-match { display: block; }

    /* Side rail — recent jobs */
    .rail h6 {
        font-size: var(--t-meta);
        color: var(--fg-3);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        font-weight: 600;
        padding-bottom: var(--s-sm);
        border-bottom: 1px solid var(--rule);
        margin-bottom: var(--s-sm);
    }
    .rail ol {
        list-style: none;
        padding: 0; margin: 0;
        display: flex;
        flex-direction: column;
    }
    .rail li {
        padding: var(--s-sm) 0;
        border-bottom: 1px solid var(--rule);
        font-size: var(--t-ui);
        display: grid;
        grid-template-columns: auto 1fr auto;
        gap: 0.6em;
        align-items: center;
    }
    .rail li:last-child { border-bottom: none; }
    /* Status in rail: disc + 3-letter mono label so meaning isn't color-only. */
    .rail .status { font-size: var(--t-meta); color: var(--fg-2); }
    .rail .name { color: var(--fg-0); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .rail .when { font-family: var(--mono); font-variation-settings: var(--rec-mono-tight); font-size: var(--t-meta); color: var(--fg-3); letter-spacing: 0; }
    .rail__empty {
        padding: var(--s-md) 0;
        font-family: var(--mono);
        font-variation-settings: var(--rec-mono);
        font-size: var(--t-ui);
        color: var(--fg-3);
    }
    .rail__more {
        margin-top: var(--s-sm);
        font-size: var(--t-meta);
        color: var(--fg-3);
        font-family: var(--mono);
        font-variation-settings: var(--rec-mono-tight);
    }
    .roster .col-never {
        font-family: var(--mono);
        font-variation-settings: var(--rec-mono-tight);
        font-size: var(--t-meta);
        color: var(--fg-3);
    }

    @@media (max-width: 1000px) {
        .home { grid-template-columns: 1fr; }
    }
</style>

<section class="home" data-home>
    <article>
        <div class="roster__head">
            <div class="roster__title">
                <h2>Scripts</h2>
                <div class="summary" data-summary>
                    @{
                        var n = scripts?.Count ?? 0;
                    }
                    <span data-numeric>@n</span> @(n == 1 ? "script" : "scripts")
                    <span data-jobs-block style="@(recentJobs != null && recentJobs.Any() ? "" : "display:none")">
                        &middot; <span data-numeric data-jobs-total>@(completed24h + failed24h)</span> jobs / 24h
                        <span data-failed-block style="@(failed24h > 0 ? "" : "display:none")">
                            (<a href="/Scripts/Jobs" class="fail"><span data-numeric data-failed-count>@failed24h</span> failed</a>)
                        </span>
                    </span>
                    &middot; <a data-shortcuts-open="concepts">how scripts work ›</a>
                </div>
            </div>
            @if (canAuthor)
            {
                <a href="/PowerShell/Create" class="add">+ new script</a>
            }
        </div>

        @if (scripts != null && scripts.Any())
        {
            <div class="roster__filter">
                <div class="filter-wrap">
                    <input type="search"
                           id="roster-filter"
                           data-roster-filter
                           placeholder="filter by name, author, or category"
                           autocomplete="off"
                           spellcheck="false"
                           aria-label="Filter scripts" />
                    <button type="button" class="filter-clear" data-roster-filter-clear hidden aria-label="Clear filter (esc)" title="Clear (esc)">[ x ]</button>
                </div>
                <div class="filter-meta" data-filter-meta>
                    <span data-numeric data-visible-count>@n</span> / <span data-numeric>@n</span>
                </div>
            </div>

            <table class="roster" data-numeric data-roster>
                <thead>
                    <tr>
                        <th data-sort-key="name" tabindex="0" role="columnheader" aria-sort="none">name</th>
                        <th data-sort-key="author" tabindex="0" role="columnheader" aria-sort="none">author</th>
                        <th data-sort-key="last-status" tabindex="0" role="columnheader" aria-sort="none">last status</th>
                        <th data-sort-key="last-run" tabindex="0" role="columnheader" aria-sort="none">last run</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                @{ var lastFailedScriptId = recentJobs?.FirstOrDefault(j => j.Status == Status.Failed)?.ScriptId; }
                @foreach (var s in scripts)
                {
                    var lastJob = recentJobs?.FirstOrDefault(j => j.ScriptId == s.Id);
                    var classes = new System.Collections.Generic.List<string>();
                    if (s.Id == lastFailedScriptId) classes.Add("is-last-failed");
                    if (runningJob != null && runningJob.ScriptId == s.Id) classes.Add("is-running");
                    var rowClass = string.Join(' ', classes);
                    var category = s.Category?.Name ?? "uncategorised";
                    var author = string.IsNullOrEmpty(s.Author) ? "—" : s.Author;
                    var filterKey = $"{s.Name} {author} {category}".ToLowerInvariant();
                    <tr class="@rowClass" data-row data-script-id="@s.Id" data-filter-key="@filterKey">
                        <td class="col-name">
                            <a asp-controller="PowerShell" asp-action="Details" asp-route-id="@s.Id" data-row-link>@s.Name</a>
                            <span class="cat">@category</span>
                        </td>
                        <td class="col-author">@author</td>
                        <td data-status-cell>
                            @if (runningJob != null && runningJob.ScriptId == s.Id)
                            {
                                <span class="status" data-state="running">running</span>
                            }
                            else if (lastJob != null && lastJob.Status == Status.Failed && !string.IsNullOrEmpty(lastJob.Outcome))
                            {
                                <span class="status" data-state="failed" title="@firstLine(lastJob.Outcome)">failed</span>
                            }
                            else if (lastJob != null)
                            {
                                <span class="status" data-state="@statusToken(lastJob.Status)">@statusLabel(lastJob.Status)</span>
                            }
                            else
                            {
                                <span class="col-never">never run</span>
                            }
                        </td>
                        <td class="col-last" data-last-cell data-last-iso="@(lastJob != null ? lastJob.Date.ToString("o") : "")">@(lastJob != null ? ago(lastJob.Date) : "—")</td>
                        <td class="col-action">
                            <a class="open" asp-controller="PowerShell" asp-action="Details" asp-route-id="@s.Id" title="Open @s.Name" data-open>open ›</a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
            <div class="roster__no-match">$ no scripts match.</div>
        }
        else
        {
            <div class="roster__empty">
                <p>$ ls scripts/ &mdash; <span style="color: var(--fg-3)">empty</span></p>
                @if (canAuthor)
                {
                    <p>No scripts in any category you can see. <a href="/PowerShell/Create">Add one</a> to get started.</p>
                }
                else
                {
                    <p>
                        No scripts in any category you can see.
                        Categories control what you can run; ask an administrator to grant you one, or to add a script.
                    </p>
                }
            </div>
        }
    </article>

    <aside class="rail" data-rail>
        <h6>Recent activity</h6>
        <ol data-rail-list style="@(recentJobs != null && recentJobs.Any() ? "" : "display:none")">
        @if (recentJobs != null)
        {
            foreach (var j in recentJobs)
            {
                <li data-rail-iso="@j.Date.ToString("o")">
                    <span class="status" data-state="@statusToken(j.Status)" title="@statusLabel(j.Status)">@statusShort(j.Status)</span>
                    <span class="name" title="@(j.Script?.Name ?? "(deleted)")">@(j.Script?.Name ?? "(deleted)")</span>
                    <span class="when">@ago(j.Date)</span>
                </li>
            }
        }
        </ol>
        <p class="rail__more" data-rail-more style="@(recentJobs != null && recentJobs.Any() ? "" : "display:none")"><a href="/Scripts/Jobs">full audit ›</a></p>
        <div class="rail__empty" data-rail-empty style="@(recentJobs == null || !recentJobs.Any() ? "" : "display:none")">$ no jobs in 24h</div>
    </aside>
</section>
