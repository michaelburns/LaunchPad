@model AdminViewModel
@{
    ViewData["Title"] = $"Edit · {Model.User.Username}";
    var availableRoles = (Model.AvailableRoles ?? new Microsoft.AspNetCore.Mvc.Rendering.SelectList(new System.Collections.Generic.List<object>(), "Id", "Name")).ToList();
    var availableCats  = (Model.AvailableCategories ?? new Microsoft.AspNetCore.Mvc.Rendering.SelectList(new System.Collections.Generic.List<object>(), "Id", "Name")).ToList();
    var selectedRoles = Model.SelectedRoles?.ToList() ?? new System.Collections.Generic.List<int>();
    var selectedCats  = Model.SelectedCategories?.ToList() ?? new System.Collections.Generic.List<int>();
}

<style>
    .author { display: grid; grid-template-columns: 1fr; gap: var(--s-xl); max-width: 760px; }
    .author__head {
        display: flex; align-items: flex-end; justify-content: space-between;
        gap: var(--s-md); padding-bottom: var(--s-md); border-bottom: 1px solid var(--rule);
        flex-wrap: wrap;
    }
    .author__title { display: flex; align-items: baseline; gap: var(--s-md); flex-wrap: wrap; }
    .author__title h1 { font-size: var(--t-h2); letter-spacing: -0.022em; }
    .author__title .meta {
        font-family: var(--mono);
        font-variation-settings: var(--rec-mono-tight);
        font-size: var(--t-meta);
        color: var(--fg-3);
    }
    .author__head__actions { display: flex; gap: var(--s-xs); align-items: center; }

    .notice, .notice-error {
        font-family: var(--mono);
        font-variation-settings: var(--rec-mono-tight);
        font-size: var(--t-meta);
        padding: var(--s-sm) var(--s-md);
        border: 1px solid var(--rule);
        border-radius: 4px;
        background: var(--bg-1);
        color: var(--fg-1);
    }
    .notice-error {
        border-color: color-mix(in oklab, var(--fail) 45%, var(--rule-strong));
        background: color-mix(in oklab, var(--fail) 8%, var(--bg-1));
        color: var(--fail);
    }

    .author__form { display: grid; gap: var(--s-lg); }
    .author__row { display: grid; grid-template-columns: 180px 1fr; gap: var(--s-md); align-items: start; }
    .author__row > label, .author__row > .label {
        font-size: var(--t-meta);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--fg-2);
        margin: 0.4em 0 0;
    }
    .author__row .field-help {
        display: block;
        margin-top: var(--s-2xs);
        font-family: var(--mono);
        font-variation-settings: var(--rec-mono-tight);
        font-size: var(--t-meta);
        color: var(--fg-3);
    }
    .author__row input[type="text"] { max-width: 36ch; }

    .checklist {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 0.4em;
        background: var(--bg-1);
        border: 1px solid var(--rule);
        border-radius: 4px;
        padding: var(--s-sm);
    }
    .checklist label {
        display: flex; align-items: center; gap: 0.5em;
        font-family: var(--sans);
        font-size: var(--t-ui);
        color: var(--fg-1);
        text-transform: none;
        letter-spacing: 0;
        font-weight: normal;
        padding: 0.4em 0.5em;
        border-radius: 3px;
        cursor: pointer;
        margin: 0;
    }
    .checklist label:hover { background: var(--bg-2); color: var(--fg-0); }
    .checklist input[type="checkbox"] { accent-color: var(--accent); margin: 0; }
    .checklist__empty {
        font-family: var(--mono);
        font-variation-settings: var(--rec-mono);
        font-size: var(--t-meta);
        color: var(--fg-3);
        padding: 0.5em;
    }

    .author__actions {
        display: flex; gap: var(--s-md); align-items: center; flex-wrap: wrap;
        padding-top: var(--s-md); border-top: 1px solid var(--rule);
    }

    .danger-zone-row {
        margin-top: var(--s-xl);
        padding-top: var(--s-md);
        border-top: 1px dashed color-mix(in oklab, var(--fail) 35%, var(--rule));
        display: flex;
        align-items: center;
        gap: var(--s-md);
        flex-wrap: wrap;
    }
    .danger-zone-row__label {
        font-family: var(--mono);
        font-variation-settings: var(--rec-mono-tight);
        font-size: var(--t-micro);
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: color-mix(in oklab, var(--fail) 55%, var(--fg-3));
    }
    .danger-zone-row__forms { display: flex; gap: var(--s-xs); margin-left: auto; }
    .danger-zone-row form { display: inline-flex; }
    .danger-zone-row__lockmsg {
        font-family: var(--mono);
        font-variation-settings: var(--rec-mono-tight);
        font-size: var(--t-meta);
        color: var(--fg-3);
        flex: 1 1 auto;
        max-width: 56ch;
    }
    .danger-zone-row button[disabled] {
        opacity: 0.4;
        cursor: not-allowed;
        pointer-events: none;
    }

    .validation-summary-errors,
    .field-validation-error,
    .text-danger {
        color: var(--fail);
        font-family: var(--mono);
        font-variation-settings: var(--rec-mono);
        font-size: var(--t-meta);
    }
    .validation-summary-errors {
        padding: var(--s-sm) var(--s-md);
        background: color-mix(in oklab, var(--fail) 8%, var(--bg-1));
        border: 1px solid color-mix(in oklab, var(--fail) 45%, var(--rule-strong));
        border-radius: 4px;
        margin-bottom: var(--s-md);
    }

    @@media (max-width: 720px) {
        .author__row { grid-template-columns: 1fr; }
        .danger-zone-row__forms { margin-left: 0; }
    }
</style>

<section class="author">
    <header class="author__head">
        <div class="author__title">
            <h1>@Model.User.Username</h1>
            <span class="meta">edit user</span>
        </div>
        <div class="author__head__actions">
            <a class="ghost" asp-action="UserList">cancel</a>
        </div>
    </header>

    @if (TempData["AdminNotice"] is string okMsg)
    {
        <div class="notice">@okMsg</div>
    }
    @if (TempData["AdminError"] is string errMsg)
    {
        <div class="notice-error">@errMsg</div>
    }

    <form asp-action="UserEdit" method="post" class="author__form" data-author-form>
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="User.Id" />
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="author__row">
            <label asp-for="User.Username">username</label>
            <div>
                <input asp-for="User.Username" autocomplete="off" spellcheck="false" required />
                <span asp-validation-for="User.Username" class="field-validation-error"></span>
            </div>
        </div>

        <div class="author__row">
            <span class="label">roles</span>
            <div>
                @if (availableRoles.Any())
                {
                    <div class="checklist">
                        @foreach (var role in availableRoles)
                        {
                            var rid = int.Parse(role.Value);
                            <label>
                                <input type="checkbox" name="SelectedRoles" value="@rid" @(selectedRoles.Contains(rid) ? "checked" : "") />
                                <span>@role.Text</span>
                            </label>
                        }
                    </div>
                }
                else
                {
                    <div class="checklist"><span class="checklist__empty">$ no roles defined</span></div>
                }
                <span asp-validation-for="SelectedRoles" class="field-validation-error"></span>
                <span class="field-help"><code>Author</code> can edit scripts; <code>Launcher</code> can run them; <code>Administrator</code> can manage access.</span>
            </div>
        </div>

        <div class="author__row">
            <span class="label">categories</span>
            <div>
                @if (availableCats.Any())
                {
                    <div class="checklist">
                        @foreach (var cat in availableCats)
                        {
                            var cid = int.Parse(cat.Value);
                            <label>
                                <input type="checkbox" name="SelectedCategories" value="@cid" @(selectedCats.Contains(cid) ? "checked" : "") />
                                <span>@cat.Text</span>
                            </label>
                        }
                    </div>
                }
                else
                {
                    <div class="checklist"><span class="checklist__empty">$ no categories yet — <a asp-action="CategoryCreate">create one</a> first</span></div>
                }
                <span asp-validation-for="SelectedCategories" class="field-validation-error"></span>
            </div>
        </div>

        <div class="author__actions">
            <button type="submit" class="btn btn-primary">save changes</button>
            <a class="ghost" asp-action="UserList">cancel</a>
        </div>
    </form>

    @{
        var isSelf      = (bool)(ViewBag.IsSelf      ?? false);
        var isLastAdmin = (bool)(ViewBag.IsLastAdmin ?? false);
        var locked      = isSelf || isLastAdmin;
        string lockMsg  = isSelf
            ? "You're signed in as this user — ask another admin to do this."
            : "This is the last Administrator on the system — grant another user that role first.";
    }
    <div class="danger-zone-row">
        <span class="danger-zone-row__label">danger zone</span>
        @if (locked)
        {
            <span class="danger-zone-row__lockmsg">@lockMsg</span>
        }
        <div class="danger-zone-row__forms">
            <form asp-action="RevokeAccess" asp-route-id="@Model.User.Id" method="post" data-arm-form>
                @Html.AntiForgeryToken()
                <button type="submit" class="ghost is-danger" data-arm-btn data-armed-label="confirm revoke" @(locked ? "disabled" : "") title="@(locked ? lockMsg : "Strip all roles from this user. Account stays; they can't satisfy any policy until granted again.")">revoke roles</button>
            </form>
            <form asp-action="UserDelete" asp-route-id="@Model.User.Id" method="post" data-arm-form>
                @Html.AntiForgeryToken()
                <button type="submit" class="ghost is-danger" data-arm-btn data-armed-label="confirm delete" @(locked ? "disabled" : "") title="@(locked ? lockMsg : "Delete this user account. Audit history rows referencing the username remain.")">delete user</button>
            </form>
        </div>
    </div>
</section>
